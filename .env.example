APP_NAME=Project W API
APP_ENV=local
APP_BASE_URL=http://localhost:8000
API_PREFIX=/api/v1
LOG_LEVEL=INFO

DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/project_w

JWT_ISSUER=project-w-api
JWT_AUDIENCE=project-w-web
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30
PASSWORD_PEPPER=replace-with-a-long-random-pepper

TRUST_CLOUDFLARE_HEADERS=false
