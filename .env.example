APP_NAME=Project W API
APP_ENV=local
APP_BASE_URL=http://localhost:8000
WEB_BASE_URL=http://localhost:3000
API_PREFIX=/api/v1
LOG_LEVEL=INFO

DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/project_w

JWT_ISSUER=project-w-api
JWT_AUDIENCE=project-w-web
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30
PASSWORD_PEPPER=replace-with-a-long-random-pepper
REFRESH_COOKIE_NAME=refresh_token
EMAIL_VERIFICATION_TTL_HOURS=24
PASSWORD_RESET_TTL_MINUTES=30

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-gmail-address@gmail.com
MAIL_PASSWORD="your-gmail-app-password"
MAIL_FROM_EMAIL=your-gmail-address@gmail.com
MAIL_FROM_NAME=Project W
MAIL_STARTTLS=true
MAIL_TIMEOUT_SECONDS=10

REDIS_URL=redis://localhost:6379/0

TRUST_CLOUDFLARE_HEADERS=false
TMDB_API_KEY=your_tmdb_api_key_here
RAWG_API_KEY=your_rawg_api_key_here
GOOGLE_BOOKS_API_KEY=your_google_books_api_key_here
OPEN_LIBRARY_USER_AGENT=multi-media-library/1.0 (contact@example.com)
OPEN_LIBRARY_CONTACT_EMAIL=contact@example.com
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
PROVIDER_TIMEOUT_SECONDS=10
PROVIDER_MAX_RETRIES=2

CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=
# Leave empty for a private bucket; the API will serve authenticated owner downloads.
CLOUDFLARE_R2_PUBLIC_BASE_URL=
PROFILE_IMAGE_MAX_BYTES=5242880
PROFILE_IMAGE_MAX_DIMENSION=4096
PROFILE_IMAGE_MAX_PIXELS=16000000
