              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "if (body && body.length > 0) {",
                  "  const item = body[0];",
                  "  if (item.id) { pm.environment.set('last_media_id', item.id); }",
                  "  if (item.external_id) {",
                  "    pm.environment.set('last_external_id', item.external_id);",
                  "    pm.environment.set('last_external_provider', item.provider || 'tmdb');",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        },
